# Example node environment. The REAL file is /etc/rescue-mesh/node.env,
# generated by deploy/setup_node.sh with fresh secrets (never commit real
# values; file 09 F4). This example uses dev-only placeholders.

# Identity (file 01 step 7)
NODE_ID=DRONE_A
USER_AP_SSID=RESCUE_A
DTN_IP=10.99.0.1
DTN_PEERS=10.99.0.2,10.99.0.3

# Ports
API_HOST=0.0.0.0
API_PORT=8443
HTTP_HOST=0.0.0.0
HTTP_PORT=80

# Storage
DB_FILE=drone_mesh.db
AUDIT_LOG_FILE=audit.log

# Trust root: ONE master secret; K_msg / K_sync / K_token are derived with
# HKDF (file 09 F2). Generate with: openssl rand -hex 32
NODE_MASTER_SECRET=dev_master_secret_change_me

# Break-glass static keys (file 09 plane 2: demoted, store offline)
RESCUE_API_KEY=dev_rescue_key_change_me
HQ_API_KEY=dev_hq_key_change_me

# TLS for the authenticated plane (certs issued by deploy/make_fleet_ca.sh)
API_TLS_ENABLED=true
API_TLS_CERT=keys/node_cert.pem
API_TLS_KEY=keys/node_key.pem
# Inter-node mTLS: documented option, OFF by default (file 09 D1)
API_MTLS_ENABLED=false
API_MTLS_CA_CERT=keys/fleet_ca.crt

# Sync daemon (file 02 task 2.3)
BEACON_ADDR=10.99.0.255
BEACON_PORT=48555
BEACON_INTERVAL=10
PEER_EXPIRY=35
SYNC_INTERVAL=30
SYNC_SCHEME=https
SYNC_VERIFY_TLS=true
SYNC_CA_CERT=keys/fleet_ca.crt

# Aux bridge (file 02 task 2.2). Empty AUX_SERIAL = no aux module (DRONE_S).
AUX_SERIAL=/dev/ttyACM0
AUX_STATE_FILE=/run/rescue-mesh/aux_state.json

# Victim E2E encryption: OFF by default (file 09 D2)
E2E_ENABLED=false
VICTIM_E2E_PUBLIC_KEY_PATH=
E2E_ENCRYPTION_REQUIRED=false
